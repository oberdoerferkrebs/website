---
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
  title?: string;
  description?: string;
  heroMode?: boolean;
}

const { title = 'Oberdoerfer&Krebs', description = 'Oberdoerfer&Krebs is a design studio working with large-scale 3D printing, interrupted and finished by hand.', heroMode = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- if JS is off, make sure the wordmark is visible (static fallback) -->
    <noscript>
      <style>
        .site-header.hero-mode .header-wordmark { display: revert; }
        .morph-mark { opacity: 1 !important; }
      </style>
    </noscript>
  </head>
  <body>
    <Header heroMode={heroMode} />
    <slot />
  </body>
</html>
