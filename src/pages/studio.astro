---
// Studio: narrow centered justified column (stand-in copy — final text
// will represent both founders evenly; the third paragraph below is the
// slot for the joint founders paragraph), then the contact list.
import Base from '../layouts/Base.astro';
import ContactList from '../components/ContactList.astro';
---

<Base title="Studio — Oberdoerfer&Krebs">
  <h1 class="sr-only">Studio</h1>
  <main>
    <section class="column">
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer at
        dictum arcu, non luctus mi. Praesent efficitur, justo in vulputate
        posuere, mi lacus tincidunt urna, sed porta orci enim ac massa.
      </p>
      <p>
        Curabitur nec dignissim nibh. Sed hendrerit lacinia ligula, in
        ullamcorper sem interdum eget. Vestibulum ante ipsum primis in
        faucibus orci luctus et ultrices posuere cubilia curae.
      </p>
      <!-- slot: joint founders paragraph (both founders represented evenly) -->
      <p>
        Donec faucibus, sapien a semper facilisis, purus mi rhoncus diam, id
        egestas leo nibh eget mauris, duo conditores pariter operantur.
      </p>
      <p>
        Nulla facilisi. Aliquam erat volutpat. Suspendisse potenti. Integer
        posuere erat a ante venenatis dapibus posuere velit aliquet.
      </p>

      <div class="contact">
        <ContactList />
      </div>
    </section>
  </main>
</Base>

<style>
  main {
    min-height: 100vh;
    display: grid;
    place-items: center;
    padding: 7rem 1.5rem 4rem;
  }

  .column {
    width: 340px;
    max-width: 100%;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    font-size: 0.9rem;
  }

  .column p + p {
    margin-top: 1em;
  }

  .contact {
    margin-top: 3rem;
  }
</style>
