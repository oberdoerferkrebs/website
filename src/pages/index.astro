---
// Home. The wordmark literally morphs: it is ONE element that starts as a
// huge, centred "O&K" and becomes the small "Oberdoerfer&Krebs" in the
// header. The letters O, &, K are permanent anchors; "berdoerfer" and "rebs"
// grow out from font-size 0, pushing the anchors apart, while the whole mark
// shrinks and travels up to the header line. Nothing cross-fades — the same
// glyphs are present throughout, so the monogram literally turns into the
// header wordmark.
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectStrip from '../components/ProjectStrip.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year
);

// pool for the photo fill: every project's thumbDetail that actually exists
const heroPool = projects
  .filter((p) => p.data.thumbDetail)
  .map((p) => ({ name: p.data.title, src: p.data.thumbDetail }));
---

<Base heroMode={true}>
  <h1 class="sr-only">Oberdoerfer&amp;Krebs</h1>

  <!-- the morphing wordmark (its own fixed element, sits above the header) -->
  <a
    class="morph-mark photo-text"
    href="/"
    aria-label="Oberdoerfer & Krebs — home"
    data-pool={JSON.stringify(heroPool)}
  ><span class="anchor">O</span><span class="fill">berdoerfer</span><span
      class="anchor">&amp;</span><span class="anchor">K</span><span class="fill"
      >rebs</span></a>

  <!-- scroll room so the morph has somewhere to happen -->
  <div class="hero-spacer" aria-hidden="true"></div>

  <main>
    <!-- intro (stand-in copy — final text comes later) -->
    <section class="intro">
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer at
        dictum arcu, non luctus mi. Praesent efficitur, justo in vulputate
        posuere, mi lacus tincidunt urna, sed porta orci enim ac massa.
      </p>
      <p>
        Curabitur nec dignissim nibh. Sed hendrerit lacinia ligula, in
        ullamcorper sem interdum eget. Vestibulum ante ipsum primis in
        faucibus orci luctus et ultrices posuere cubilia curae.
      </p>
      <p>
        Donec faucibus, sapien a semper facilisis, purus mi rhoncus diam, id
        egestas leo nibh eget mauris. Nulla facilisi. Aliquam erat volutpat.
      </p>
    </section>

    <!-- project strip -->
    <ProjectStrip projects={projects} />
  </main>
</Base>

<script>
  // 1) Pick the photo that fills the wordmark (random per view, never a repeat).
  const mark = document.querySelector<HTMLAnchorElement>('.morph-mark');
  const pool: { name: string; src: string }[] = JSON.parse(
    mark?.dataset.pool || '[]'
  );
  if (mark && pool.length > 0) {
    const prev = sessionStorage.getItem('ok-hero-prev');
    let candidates = pool.filter((p) => p.src !== prev);
    if (candidates.length === 0) candidates = pool;
    const pick = candidates[Math.floor(Math.random() * candidates.length)];
    sessionStorage.setItem('ok-hero-prev', pick.src);
    document.documentElement.style.setProperty('--hero-img', `url("${pick.src}")`);
    document.documentElement.classList.add('has-photo');
    mark.setAttribute('aria-label', `Oberdoerfer & Krebs — ${pick.name} — home`);
  }

  // 2) The morph itself.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const fills = mark ? Array.from(mark.querySelectorAll<HTMLElement>('.fill')) : [];

  if (mark && !reduce) {
    document.documentElement.classList.add('hero-anim');
    mark.style.opacity = '1';

    const clamp01 = (v: number) => Math.min(1, Math.max(0, v));
    let vw = 0, vh = 0, headerCenterY = 0, ticking = false;

    const measure = () => {
      vw = window.innerWidth;
      vh = window.innerHeight;
      const nav = document.querySelector('.nav-left');
      const r = nav?.getBoundingClientRect();
      headerCenterY = r ? r.top + r.height / 2 : 30;
    };

    const SMALL = 1.2 * 16; // final size = 1.2rem, matching the header wordmark

    const update = () => {
      ticking = false;
      const big = Math.min(vw * 0.34, 340); // starting O&K size
      // hold the big O&K for the first stretch, then morph quickly
      const startAt = vh * 0.5;
      const distance = vh * 0.4;
      const p = clamp01((window.scrollY - startAt) / distance);

      // overall shrink, and the fills growing out of the anchors
      mark.style.fontSize = big + (SMALL - big) * p + 'px';
      const fillP = clamp01((p - 0.08) / 0.82);
      fills.forEach((f) => (f.style.fontSize = fillP + 'em'));

      // re-centre after the layout settles; travel from screen centre to header
      const rect = mark.getBoundingClientRect();
      const centerY = vh / 2 + (headerCenterY - vh / 2) * p;
      mark.style.left = (vw - rect.width) / 2 + 'px';
      mark.style.top = centerY - rect.height / 2 + 'px';
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    measure();
    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => {
      measure();
      update();
    });
  } else if (mark) {
    mark.style.opacity = '1'; // reduced motion: static full wordmark at the top
  }
</script>

<style>
  /* The morphing wordmark. Default (no JS / reduced motion) is the small full
     wordmark centred at the top — a clean static fallback. */
  .morph-mark {
    position: fixed;
    top: 1.1rem;
    left: 0;
    right: 0;
    z-index: 101;
    text-align: center;
    white-space: nowrap;
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.2rem;
    line-height: 1;
    letter-spacing: -0.03em;
    text-decoration: none;
    color: var(--color-fg);
    opacity: 0; /* revealed by JS (or the noscript fallback) to avoid a flash */
  }

  .morph-mark .fill {
    /* becomes 0 during the morph; full size otherwise */
    display: inline;
  }

  /* while animating, JS owns left/top/font-size */
  :global(html.hero-anim) .morph-mark {
    right: auto;
    text-align: left;
  }

  .hero-spacer {
    height: 6rem; /* clears the fixed header in the static fallback */
  }
  :global(html.hero-anim) .hero-spacer {
    /* tall enough that the page content stays below the fold through the
       hold + morph, so it never overlaps the big centred O&K */
    height: 190vh;
  }

  /* step rhythm: uniform 6vh between the steps */
  .intro {
    width: 320px;
    max-width: calc(100% - 3rem);
    margin: var(--step-gap) auto;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    font-size: 0.9rem;
    color: var(--color-fg);
  }

  .intro p + p {
    margin-top: 1em;
  }

  main {
    padding-bottom: var(--step-gap);
  }
</style>
