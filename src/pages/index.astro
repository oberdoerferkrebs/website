---
// Home: three vertical steps on a uniform 6vh rhythm —
// 1. 100vh hero with the O&K monogram (photo-filled SVG text),
// 2. narrow justified intro column,
// 3. the project strip.
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectStrip from '../components/ProjectStrip.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year
);

// pool for the hero fill: every project's thumbDetail that actually exists
const heroPool = projects
  .filter((p) => p.data.thumbDetail)
  .map((p) => ({ name: p.data.title, src: p.data.thumbDetail }));
---

<Base heroMode={true}>
  <h1 class="sr-only">Oberdoerfer&amp;Krebs</h1>

  <main>
    <!-- step 1: hero -->
    <section class="hero">
      <svg
        class="monogram"
        viewBox="0 0 980 300"
        role="img"
        aria-label="O&K — Oberdoerfer&Krebs."
        data-pool={JSON.stringify(heroPool)}
      >
        <defs>
          <clipPath id="monogram-clip" clipPathUnits="userSpaceOnUse">
            <text
              x="490"
              y="290"
              text-anchor="middle"
              textLength="960"
              lengthAdjust="spacingAndGlyphs">O&amp;K</text
            >
          </clipPath>
        </defs>
        <g clip-path="url(#monogram-clip)">
          <rect class="monogram-fallback" x="0" y="0" width="980" height="300"></rect>
          <image
            class="monogram-photo"
            href=""
            x="0"
            y="0"
            width="980"
            height="300"
            preserveAspectRatio="xMidYMid slice"></image>
        </g>
      </svg>
    </section>

    <!-- step 2: intro (stand-in copy — final text comes later) -->
    <section class="intro">
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer at
        dictum arcu, non luctus mi. Praesent efficitur, justo in vulputate
        posuere, mi lacus tincidunt urna, sed porta orci enim ac massa.
      </p>
      <p>
        Curabitur nec dignissim nibh. Sed hendrerit lacinia ligula, in
        ullamcorper sem interdum eget. Vestibulum ante ipsum primis in
        faucibus orci luctus et ultrices posuere cubilia curae.
      </p>
      <p>
        Donec faucibus, sapien a semper facilisis, purus mi rhoncus diam, id
        egestas leo nibh eget mauris. Nulla facilisi. Aliquam erat volutpat.
      </p>
    </section>

    <!-- step 3: project strip -->
    <ProjectStrip projects={projects} />
  </main>
</Base>

<script>
  // Hero fill: pick a random project thumbDetail per page view, never the
  // same as the previous view (tracked in sessionStorage). With an empty
  // pool the grey fallback rect stays visible.
  const svg = document.querySelector<SVGSVGElement>('.monogram');
  const photo = document.querySelector<SVGImageElement>('.monogram-photo');
  if (svg && photo) {
    const pool: { name: string; src: string }[] = JSON.parse(
      svg.dataset.pool || '[]'
    );
    if (pool.length > 0) {
      const prev = sessionStorage.getItem('ok-hero-prev');
      let candidates = pool.filter((p) => p.src !== prev);
      if (candidates.length === 0) candidates = pool;
      const pick = candidates[Math.floor(Math.random() * candidates.length)];
      sessionStorage.setItem('ok-hero-prev', pick.src);
      photo.setAttribute('href', pick.src);
      svg.setAttribute(
        'aria-label',
        `O&K — Oberdoerfer&Krebs. ${pick.name} photograph.`
      );
    }
  }
</script>

<script>
  // Scroll transition: as you scroll the first ~80vh, the big O&K monogram
  // shrinks and rises up into the header, fading out as the centred
  // "Oberdoerfer&Krebs" wordmark fades in. Only runs when motion is allowed;
  // otherwise the page scrolls normally and the wordmark is always visible.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const mark = document.querySelector<SVGSVGElement>('.monogram');
  const wordmark = document.querySelector<HTMLElement>('.header-wordmark');

  if (mark && wordmark && !reduce) {
    document.documentElement.classList.add('hero-anim');

    let ticking = false;
    const update = () => {
      ticking = false;
      const vh = window.innerHeight;
      const distance = vh * 0.8; // transition completes over ~80vh of scroll
      const p = Math.min(1, Math.max(0, window.scrollY / distance));

      // monogram: scale down, rise toward the header line, fade out near the end
      const scale = 1 - 0.85 * p;
      const rise = (vh / 2 - 30) * p; // travel from viewport centre up to the nav
      const opacity = p < 0.7 ? 1 : Math.max(0, 1 - (p - 0.7) / 0.3);
      mark.style.transform = `translate(-50%, calc(-50% - ${rise}px)) scale(${scale})`;
      mark.style.opacity = String(opacity);
      mark.style.pointerEvents = p > 0.99 ? 'none' : '';

      // centred header wordmark: fades in as the monogram lands
      wordmark.style.opacity = String(Math.max(0, (p - 0.55) / 0.45));
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update);
    update();
  } else if (wordmark) {
    wordmark.style.opacity = '1'; // reduced motion: keep the wordmark visible
  }
</script>

<style>
  .hero {
    height: 100vh;
    display: grid;
    place-items: center;
    padding: 0 1.5rem;
  }

  .monogram {
    width: min(100%, 980px);
    height: auto;
  }

  /* When the scroll transition is active (JS on, motion allowed), the
     monogram is pinned to the viewport centre so it can shrink and rise up
     into the header as you scroll. Default (no JS / reduced motion) leaves
     it in normal flow, scrolling away like any hero. */
  :global(html.hero-anim) .monogram {
    position: fixed;
    top: 50%;
    left: 50%;
    width: min(90%, 980px);
    transform: translate(-50%, -50%);
    transform-origin: center center;
    z-index: 1; /* below the header, so it slides under the nav as it rises */
    will-change: transform, opacity;
  }

  .monogram text {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 370px;
  }

  .monogram-fallback {
    fill: var(--color-placeholder);
  }

  /* step rhythm: uniform 6vh between the three steps */
  .intro {
    width: 320px;
    max-width: calc(100% - 3rem);
    margin: var(--step-gap) auto;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    font-size: 0.9rem;
    color: var(--color-fg);
  }

  .intro p + p {
    margin-top: 1em;
  }

  main {
    padding-bottom: var(--step-gap);
  }
</style>
