---
// Home: three vertical steps on a uniform 6vh rhythm —
// 1. 100vh hero with the big photo-filled "O&K",
// 2. narrow justified intro column,
// 3. the project strip.
//
// The hero mark and the header wordmark are both text clipped over the SAME
// viewport-fixed picture (background-clip: text + background-attachment:
// fixed). Because the picture is one fixed backdrop, it never moves or
// resizes — as you scroll, the letters reform from "O&K" into
// "Oberdoerfer&Krebs" over an unchanging image.
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectStrip from '../components/ProjectStrip.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year
);

// pool for the hero fill: every project's thumbDetail that actually exists
const heroPool = projects
  .filter((p) => p.data.thumbDetail)
  .map((p) => ({ name: p.data.title, src: p.data.thumbDetail }));
---

<Base heroMode={true}>
  <h1 class="sr-only">Oberdoerfer&amp;Krebs</h1>

  <main>
    <!-- step 1: hero -->
    <section class="hero" data-pool={JSON.stringify(heroPool)}>
      <div class="photo-text mark-big" aria-hidden="true">O&amp;K</div>
    </section>

    <!-- step 2: intro (stand-in copy — final text comes later) -->
    <section class="intro">
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer at
        dictum arcu, non luctus mi. Praesent efficitur, justo in vulputate
        posuere, mi lacus tincidunt urna, sed porta orci enim ac massa.
      </p>
      <p>
        Curabitur nec dignissim nibh. Sed hendrerit lacinia ligula, in
        ullamcorper sem interdum eget. Vestibulum ante ipsum primis in
        faucibus orci luctus et ultrices posuere cubilia curae.
      </p>
      <p>
        Donec faucibus, sapien a semper facilisis, purus mi rhoncus diam, id
        egestas leo nibh eget mauris. Nulla facilisi. Aliquam erat volutpat.
      </p>
    </section>

    <!-- step 3: project strip -->
    <ProjectStrip projects={projects} />
  </main>
</Base>

<script>
  // Hero fill: pick a random project thumbDetail per page view, never the
  // same as the previous view (sessionStorage). The chosen image becomes the
  // shared, viewport-fixed backdrop for BOTH the big mark and the header
  // wordmark, via the --hero-img custom property + the .has-photo class.
  const hero = document.querySelector<HTMLElement>('.hero');
  const pool: { name: string; src: string }[] = JSON.parse(
    hero?.dataset.pool || '[]'
  );
  if (pool.length > 0) {
    const prev = sessionStorage.getItem('ok-hero-prev');
    let candidates = pool.filter((p) => p.src !== prev);
    if (candidates.length === 0) candidates = pool;
    const pick = candidates[Math.floor(Math.random() * candidates.length)];
    sessionStorage.setItem('ok-hero-prev', pick.src);
    document.documentElement.style.setProperty('--hero-img', `url("${pick.src}")`);
    document.documentElement.classList.add('has-photo');

    const h1 = document.querySelector('h1.sr-only');
    if (h1) h1.textContent = `Oberdoerfer&Krebs — ${pick.name}`;
  }
</script>

<script>
  // Scroll transition: over the first ~85vh, the big "O&K" fades out while the
  // centred "Oberdoerfer&Krebs" wordmark fades in. Both are windows onto the
  // same fixed picture, so the image stays put and the same size — the text
  // simply reforms from the monogram into the full wordmark. No scaling of the
  // mark (which would shrink the picture); the big mark just scrolls up under
  // the header as normal. Only runs when motion is allowed.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const big = document.querySelector<HTMLElement>('.mark-big');
  const wordmark = document.querySelector<HTMLElement>('.header-wordmark');

  if (big && wordmark && !reduce) {
    let ticking = false;
    const lerp = (a: number, b: number, t: number) =>
      Math.min(1, Math.max(0, (t - a) / (b - a)));

    const update = () => {
      ticking = false;
      const p = Math.min(1, Math.max(0, window.scrollY / (window.innerHeight * 0.85)));
      // overlapping crossfade so both show the same picture mid-transition
      big.style.opacity = String(1 - lerp(0.15, 0.7, p));
      wordmark.style.opacity = String(lerp(0.35, 0.9, p));
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update);
    update();
  } else if (wordmark) {
    wordmark.style.opacity = '1'; // reduced motion: keep the wordmark visible
  }
</script>

<style>
  .hero {
    height: 100vh;
    display: grid;
    place-items: center;
    padding: 0 1.5rem;
  }

  .mark-big {
    font-weight: 700;
    font-size: min(23vw, 15rem);
    line-height: 1;
    letter-spacing: -0.03em;
    text-align: center;
    color: var(--color-placeholder); /* solid fallback before a photo loads */
    z-index: 1;
  }

  /* step rhythm: uniform 6vh between the three steps */
  .intro {
    width: 320px;
    max-width: calc(100% - 3rem);
    margin: var(--step-gap) auto;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    font-size: 0.9rem;
    color: var(--color-fg);
  }

  .intro p + p {
    margin-top: 1em;
  }

  main {
    padding-bottom: var(--step-gap);
  }
</style>
