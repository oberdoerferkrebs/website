---
// Home: three vertical steps on a uniform 6vh rhythm —
// 1. 100vh hero with the O&K monogram (photo-filled SVG text),
// 2. narrow justified intro column,
// 3. the project strip.
//
// The monogram is an SVG: the text "O&K" (weight 900, textLength-locked to
// full width) is a clipPath window onto a photograph. On scroll, the letter
// shapes shrink and rise up into the header while the photograph translates
// along with them WITHOUT scaling — the picture stays at constant size and
// simply follows the movement; only the letter windows change. At the top,
// the mark cross-fades into the header wordmark, which is itself clipped
// over the same picture.
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectStrip from '../components/ProjectStrip.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year
);

// pool for the hero fill: every project's thumbDetail that actually exists
const heroPool = projects
  .filter((p) => p.data.thumbDetail)
  .map((p) => ({ name: p.data.title, src: p.data.thumbDetail }));
---

<Base heroMode={true}>
  <h1 class="sr-only">Oberdoerfer&amp;Krebs</h1>

  <main>
    <!-- step 1: hero -->
    <section class="hero">
      <svg
        class="monogram"
        viewBox="0 0 980 300"
        role="img"
        aria-label="O&K — Oberdoerfer&Krebs."
        data-pool={JSON.stringify(heroPool)}
      >
        <defs>
          <clipPath id="monogram-clip" clipPathUnits="userSpaceOnUse">
            <text
              class="clip-text"
              x="490"
              y="290"
              text-anchor="middle"
              textLength="960"
              lengthAdjust="spacingAndGlyphs">O&amp;K</text
            >
          </clipPath>
        </defs>
        <g clip-path="url(#monogram-clip)">
          <!-- oversized fallback so the grey never runs out while travelling -->
          <rect class="monogram-fallback" x="-200" y="-2200" width="1380" height="4700"
          ></rect>
          <image
            class="monogram-photo"
            href=""
            x="0"
            y="0"
            width="980"
            height="300"
            preserveAspectRatio="xMidYMid slice"></image>
        </g>
      </svg>
    </section>

    <!-- step 2: intro (stand-in copy — final text comes later) -->
    <section class="intro">
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer at
        dictum arcu, non luctus mi. Praesent efficitur, justo in vulputate
        posuere, mi lacus tincidunt urna, sed porta orci enim ac massa.
      </p>
      <p>
        Curabitur nec dignissim nibh. Sed hendrerit lacinia ligula, in
        ullamcorper sem interdum eget. Vestibulum ante ipsum primis in
        faucibus orci luctus et ultrices posuere cubilia curae.
      </p>
      <p>
        Donec faucibus, sapien a semper facilisis, purus mi rhoncus diam, id
        egestas leo nibh eget mauris. Nulla facilisi. Aliquam erat volutpat.
      </p>
    </section>

    <!-- step 3: project strip -->
    <ProjectStrip projects={projects} />
  </main>
</Base>

<script>
  // Hero fill: pick a random project thumbDetail per page view, never the
  // same as the previous view (sessionStorage). The pick fills BOTH the
  // monogram's SVG image and (via --hero-img) the header wordmark.
  const svg = document.querySelector<SVGSVGElement>('.monogram');
  const photo = document.querySelector<SVGImageElement>('.monogram-photo');
  if (svg && photo) {
    const pool: { name: string; src: string }[] = JSON.parse(
      svg.dataset.pool || '[]'
    );
    if (pool.length > 0) {
      const prev = sessionStorage.getItem('ok-hero-prev');
      let candidates = pool.filter((p) => p.src !== prev);
      if (candidates.length === 0) candidates = pool;
      const pick = candidates[Math.floor(Math.random() * candidates.length)];
      sessionStorage.setItem('ok-hero-prev', pick.src);
      photo.setAttribute('href', pick.src);
      svg.setAttribute(
        'aria-label',
        `O&K — Oberdoerfer&Krebs. ${pick.name} photograph.`
      );
      document.documentElement.style.setProperty('--hero-img', `url("${pick.src}")`);
      document.documentElement.classList.add('has-photo');
    }
  }
</script>

<script>
  // Scroll morph: over the first ~85vh of scroll the O&K letter shapes
  // shrink and rise from the viewport centre up to the header line. The
  // photograph inside is translated by exactly the same amount — but never
  // scaled — so the picture keeps its size and follows the letters; only
  // the letter windows shrink. At the top the mark cross-fades into the
  // (photo-filled) header wordmark. Skipped under prefers-reduced-motion.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const mark = document.querySelector<SVGSVGElement>('.monogram');
  const clipText = document.querySelector<SVGTextElement>('.clip-text');
  const photoEl = document.querySelector<SVGImageElement>('.monogram-photo');
  const wordmark = document.querySelector<HTMLElement>('.header-wordmark');

  if (mark && clipText && photoEl && wordmark && !reduce) {
    document.documentElement.classList.add('hero-anim');

    const clamp01 = (v: number) => Math.min(1, Math.max(0, v));
    let ticking = false;

    const update = () => {
      ticking = false;
      const vh = window.innerHeight;
      // px -> SVG user units (viewBox is 980 wide)
      const k = mark.getBoundingClientRect().width / 980;
      const p = clamp01(window.scrollY / (vh * 0.85));

      // travel: from viewport centre up to the header centreline (~34px)
      const riseSvg = ((vh / 2 - 34) * p) / k;
      // letter windows shrink toward header-text size
      const s = 1 - 0.88 * p;

      // text: rise + scale about its visual centre (490, 157)
      clipText.setAttribute(
        'transform',
        `translate(0 ${-riseSvg}) translate(490 157) scale(${s}) translate(-490 -157)`
      );
      // picture: SAME rise, NO scale — constant size, follows the letters
      photoEl.setAttribute('transform', `translate(0 ${-riseSvg})`);

      // cross-fade into the header wordmark near the top
      mark.style.opacity = String(1 - clamp01((p - 0.55) / 0.35));
      wordmark.style.opacity = String(clamp01((p - 0.35) / 0.55));
    };

    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(update);
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update);
    update();
  } else if (wordmark) {
    wordmark.style.opacity = '1'; // reduced motion: keep the wordmark visible
  }
</script>

<style>
  .hero {
    height: 100vh;
    display: grid;
    place-items: center;
    padding: 0 1.5rem;
  }

  .monogram {
    width: min(90%, 980px);
    height: auto;
    overflow: visible;
    pointer-events: none;
  }

  /* While the morph is active the monogram is pinned to the viewport centre
     and travels/shrinks via its internal SVG transforms. z-index above the
     header background so the mark visibly lands ON the header; clicks pass
     through (pointer-events: none). Default (no JS / reduced motion) leaves
     it in normal flow, scrolling away like any hero. */
  :global(html.hero-anim) .monogram {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 101;
    will-change: opacity;
  }

  .monogram .clip-text {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 370px;
  }

  .monogram-fallback {
    fill: var(--color-placeholder);
  }

  /* step rhythm: uniform 6vh between the three steps */
  .intro {
    width: 320px;
    max-width: calc(100% - 3rem);
    margin: var(--step-gap) auto;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    font-size: 0.9rem;
    color: var(--color-fg);
  }

  .intro p + p {
    margin-top: 1em;
  }

  main {
    padding-bottom: var(--step-gap);
  }
</style>
