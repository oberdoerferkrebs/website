---
// Landing page: studio name, a "coming soon" note, and a small
// tic-tac-toe ("kryds og bolle") game to play in the meantime.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>Oberdoerfer & Krebs</title>
  </head>
  <body>
    <main>
      <h1>Oberdoerfer &amp; Krebs</h1>
      <p class="tagline">
        Site coming soon, in the meantime play a game while you are here:
      </p>

      <section class="game" aria-label="Tic-tac-toe game">
        <p class="status" id="status">X starts — click a square</p>
        <div class="board" id="board" role="grid">
          <button class="cell" type="button" data-index="0" aria-label="Square 1"></button>
          <button class="cell" type="button" data-index="1" aria-label="Square 2"></button>
          <button class="cell" type="button" data-index="2" aria-label="Square 3"></button>
          <button class="cell" type="button" data-index="3" aria-label="Square 4"></button>
          <button class="cell" type="button" data-index="4" aria-label="Square 5"></button>
          <button class="cell" type="button" data-index="5" aria-label="Square 6"></button>
          <button class="cell" type="button" data-index="6" aria-label="Square 7"></button>
          <button class="cell" type="button" data-index="7" aria-label="Square 8"></button>
          <button class="cell" type="button" data-index="8" aria-label="Square 9"></button>
        </div>
        <button class="reset" type="button" id="reset">New game</button>
      </section>
    </main>

    <script>
      const board = document.getElementById('board');
      const status = document.getElementById('status');
      const reset = document.getElementById('reset');
      const cells = Array.from(document.querySelectorAll('.cell'));

      const WINS = [
        [0, 1, 2], [3, 4, 5], [6, 7, 8], // rows
        [0, 3, 6], [1, 4, 7], [2, 5, 8], // columns
        [0, 4, 8], [2, 4, 6],            // diagonals
      ];

      let squares = Array(9).fill('');
      let current = 'X';
      let over = false;

      function winner() {
        for (const [a, b, c] of WINS) {
          if (squares[a] && squares[a] === squares[b] && squares[a] === squares[c]) {
            return { player: squares[a], line: [a, b, c] };
          }
        }
        return null;
      }

      function render() {
        cells.forEach((cell, i) => {
          cell.textContent = squares[i];
          cell.disabled = over || squares[i] !== '';
          cell.classList.toggle('win', false);
        });

        const result = winner();
        if (result) {
          over = true;
          status.textContent = `${result.player} wins!`;
          result.line.forEach((i) => cells[i].classList.add('win'));
          cells.forEach((cell) => (cell.disabled = true));
        } else if (squares.every((s) => s !== '')) {
          over = true;
          status.textContent = "It's a draw!";
        } else {
          status.textContent = `${current}'s turn`;
        }
      }

      board.addEventListener('click', (event) => {
        const cell = event.target.closest('.cell');
        if (!cell || over) return;
        const index = Number(cell.dataset.index);
        if (squares[index]) return;

        squares[index] = current;
        current = current === 'X' ? 'O' : 'X';
        render();
      });

      reset.addEventListener('click', () => {
        squares = Array(9).fill('');
        current = 'X';
        over = false;
        status.textContent = 'X starts — click a square';
        render();
      });
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    min-height: 100%;
  }

  body {
    background: #ffffff;
    color: #000000;
    font-family: Helvetica, Arial, sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    padding: 2rem 1rem;
    box-sizing: border-box;
  }

  main {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  h1 {
    font-size: 1.75rem;
    font-weight: 400;
    margin: 0;
  }

  .tagline {
    font-weight: 300;
    font-size: 1rem;
    color: #000000;
    max-width: 28rem;
    margin: 0.75rem 0 2rem;
  }

  .game {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .status {
    font-weight: 300;
    font-size: 0.95rem;
    margin: 0 0 1rem;
    min-height: 1.2em;
  }

  .board {
    display: grid;
    grid-template-columns: repeat(3, 4.5rem);
    grid-template-rows: repeat(3, 4.5rem);
    gap: 0;
    border: 1px solid #000000;
  }

  .cell {
    width: 4.5rem;
    height: 4.5rem;
    border: 1px solid #000000;
    background: transparent;
    font-family: inherit;
    font-size: 2rem;
    font-weight: 400;
    color: #000000;
    cursor: pointer;
    padding: 0;
    line-height: 1;
  }

  .cell:hover:not(:disabled) {
    background: #f2f2f2;
  }

  .cell:disabled {
    cursor: default;
  }

  .cell.win {
    background: #000000;
    color: #ffffff;
  }

  .reset {
    margin-top: 1.5rem;
    font-family: inherit;
    font-weight: 300;
    font-size: 0.9rem;
    color: #000000;
    background: transparent;
    border: 1px solid #000000;
    padding: 0.4rem 1rem;
    cursor: pointer;
  }

  .reset:hover {
    background: #000000;
    color: #ffffff;
  }
</style>
