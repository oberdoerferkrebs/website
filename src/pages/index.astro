---
// Home: three vertical steps on a uniform 6vh rhythm —
// 1. 100vh hero with the O&K monogram (photo-filled SVG text),
// 2. narrow justified intro column,
// 3. the project strip.
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectStrip from '../components/ProjectStrip.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year
);

// pool for the hero fill: every project's thumbDetail that actually exists
const heroPool = projects
  .filter((p) => p.data.thumbDetail)
  .map((p) => ({ name: p.data.title, src: p.data.thumbDetail }));
---

<Base>
  <h1 class="sr-only">Oberdoerfer&amp;Krebs</h1>

  <main>
    <!-- step 1: hero -->
    <section class="hero">
      <svg
        class="monogram"
        viewBox="0 0 980 300"
        role="img"
        aria-label="O&K — Oberdoerfer&Krebs."
        data-pool={JSON.stringify(heroPool)}
      >
        <defs>
          <clipPath id="monogram-clip" clipPathUnits="userSpaceOnUse">
            <text
              x="490"
              y="290"
              text-anchor="middle"
              textLength="960"
              lengthAdjust="spacingAndGlyphs">O&amp;K</text
            >
          </clipPath>
        </defs>
        <g clip-path="url(#monogram-clip)">
          <rect class="monogram-fallback" x="0" y="0" width="980" height="300"></rect>
          <image
            class="monogram-photo"
            href=""
            x="0"
            y="0"
            width="980"
            height="300"
            preserveAspectRatio="xMidYMid slice"></image>
        </g>
      </svg>
    </section>

    <!-- step 2: intro (stand-in copy — final text comes later) -->
    <section class="intro">
      <p>
        Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer at
        dictum arcu, non luctus mi. Praesent efficitur, justo in vulputate
        posuere, mi lacus tincidunt urna, sed porta orci enim ac massa.
      </p>
      <p>
        Curabitur nec dignissim nibh. Sed hendrerit lacinia ligula, in
        ullamcorper sem interdum eget. Vestibulum ante ipsum primis in
        faucibus orci luctus et ultrices posuere cubilia curae.
      </p>
      <p>
        Donec faucibus, sapien a semper facilisis, purus mi rhoncus diam, id
        egestas leo nibh eget mauris. Nulla facilisi. Aliquam erat volutpat.
      </p>
    </section>

    <!-- step 3: project strip -->
    <ProjectStrip projects={projects} />
  </main>
</Base>

<script>
  // Hero fill: pick a random project thumbDetail per page view, never the
  // same as the previous view (tracked in sessionStorage). With an empty
  // pool the grey fallback rect stays visible.
  const svg = document.querySelector<SVGSVGElement>('.monogram');
  const photo = document.querySelector<SVGImageElement>('.monogram-photo');
  if (svg && photo) {
    const pool: { name: string; src: string }[] = JSON.parse(
      svg.dataset.pool || '[]'
    );
    if (pool.length > 0) {
      const prev = sessionStorage.getItem('ok-hero-prev');
      let candidates = pool.filter((p) => p.src !== prev);
      if (candidates.length === 0) candidates = pool;
      const pick = candidates[Math.floor(Math.random() * candidates.length)];
      sessionStorage.setItem('ok-hero-prev', pick.src);
      photo.setAttribute('href', pick.src);
      svg.setAttribute(
        'aria-label',
        `O&K — Oberdoerfer&Krebs. ${pick.name} photograph.`
      );
    }
  }
</script>

<style>
  .hero {
    height: 100vh;
    display: grid;
    place-items: center;
    padding: 0 1.5rem;
  }

  .monogram {
    width: min(100%, 980px);
    height: auto;
  }

  .monogram text {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 370px;
  }

  .monogram-fallback {
    fill: var(--color-placeholder);
  }

  /* step rhythm: uniform 6vh between the three steps */
  .intro {
    width: 320px;
    max-width: calc(100% - 3rem);
    margin: var(--step-gap) auto;
    text-align: justify;
    hyphens: auto;
    -webkit-hyphens: auto;
    font-size: 0.9rem;
    color: var(--color-fg);
  }

  .intro p + p {
    margin-top: 1em;
  }

  main {
    padding-bottom: var(--step-gap);
  }
</style>
