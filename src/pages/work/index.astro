---
// Work index: a plain responsive grid — the working index, no hover
// theatrics.
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.year - a.data.year
);
---

<Base title="Work — Oberdoerfer&Krebs">
  <h1 class="sr-only">Work</h1>
  <main>
    <ul class="grid">
      {
        projects.map((p) => (
          <li>
            <a href={`/work/${p.data.slug}`}>
              {p.data.thumbFull ? (
                <img
                  src={p.data.thumbFull}
                  alt={p.data.title}
                  loading="lazy"
                  style={`object-position: ${p.data.focalX}% ${p.data.focalY}%;`}
                />
              ) : (
                <div class="placeholder" aria-hidden="true" />
              )}
              <p class="label">
                {p.data.title}, {p.data.year}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Base>

<style>
  main {
    padding: 7rem 1.5rem 4rem;
    max-width: 72rem;
    margin: 0 auto;
  }

  .grid {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: 2.5rem 2rem;
  }

  .grid a {
    display: block;
    text-decoration: none;
  }

  .grid img,
  .placeholder {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  .placeholder {
    background: var(--color-placeholder);
  }

  .label {
    margin-top: 0.6rem;
    font-size: 0.85rem;
  }
</style>
