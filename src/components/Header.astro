---
// Fixed site navigation, symmetric: Work · Studio on the left, the
// centered wordmark "Oberdoerfer&Krebs", and Press · Contact on the right.
//
// On the home page (heroMode), the centered wordmark starts hidden and is
// revealed by the scroll transition as the big O&K monogram shrinks up into
// it. Everywhere else the wordmark is simply always visible.
interface Props {
  heroMode?: boolean;
}
const { heroMode = false } = Astro.props;

// Section labels. These are placeholders — the sections don't exist yet, so
// they render as plain (non-linking) labels, not links. Add `href` back when
// a section is actually built.
const left = ['Work', 'Studio'];
const right = ['Press', 'Contact']; // 'Shop' reserved — add when the shop is built
---

<header class:list={['site-header', { 'hero-mode': heroMode }]}>
  <nav class="nav nav-left" aria-label="Primary">
    {left.map((label) => <span class="nav-label">{label}</span>)}
  </nav>

  <a class="header-wordmark" href="/">Oberdoerfer&amp;Krebs</a>

  <nav class="nav nav-right" aria-label="Secondary">
    {right.map((label) => <span class="nav-label">{label}</span>)}
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(6px);
  }

  .nav {
    display: flex;
    gap: 1.4rem;
  }
  /* pin each part to its column so hiding the centre wordmark on the home
     page can't cause the nav to re-flow into the wrong columns */
  .nav-left {
    grid-column: 1;
    justify-self: start;
  }
  .header-wordmark {
    grid-column: 2;
  }
  .nav-right {
    grid-column: 3;
    justify-self: end;
  }
  .nav-label {
    font-size: 0.9rem;
    color: var(--color-fg);
  }

  .header-wordmark {
    justify-self: center;
    font-family: var(--font-display);
    /* fat + a bit larger so the picture clipped inside it actually reads */
    font-weight: 900;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    text-decoration: none;
    white-space: nowrap;
  }

  /* home page: the morphing .morph-mark stands in for the wordmark, so the
     header's own copy is hidden there. */
  .site-header.hero-mode .header-wordmark {
    display: none;
  }

  /* mobile: wordmark centered on its own row, nav groups centered below */
  @media (max-width: 40rem) {
    .site-header {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      row-gap: 0.5rem;
      column-gap: 1.5rem;
      padding: 0.9rem 1rem;
    }
    .header-wordmark {
      flex-basis: 100%;
      text-align: center;
      order: -1;
      font-size: 0.9rem;
    }
    .nav {
      gap: 1rem;
    }
  }
</style>
