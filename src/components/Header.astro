---
// Fixed site navigation. The wordmark is always "Oberdoerfer&Krebs" —
// no spaces around the ampersand, everywhere.
const links = [
  { href: '/work', label: 'Work' },
  { href: '/studio', label: 'Studio' },
  { href: '/press', label: 'Press' },
  // { href: '/shop', label: 'Shop' }, // reserved — enable when the shop is built
  { href: '/contact', label: 'Contact' },
];
---

<header class="site-header">
  <a class="wordmark" href="/">Oberdoerfer&amp;Krebs</a>
  <nav aria-label="Primary">
    {links.map((l) => <a href={l.href}>{l.label}</a>)}
  </nav>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.5rem;
    background: rgba(255, 255, 255, 0.92);
  }

  .wordmark {
    font-family: var(--font-display);
    font-size: 0.95rem;
    letter-spacing: 0.01em;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 1.4rem;
  }

  nav a {
    font-size: 0.9rem;
    color: var(--color-fg);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--color-muted);
  }

  @media (max-width: 40rem) {
    .site-header {
      padding: 1rem;
    }
    nav {
      gap: 1rem;
    }
  }
</style>
