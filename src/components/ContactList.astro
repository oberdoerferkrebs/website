---
// Label/value contact list: small-caps labels left, values right.
// Used on /studio and /contact.
---

<dl class="contact-list">
  <div class="row">
    <dt>Instagram</dt>
    <dd>
      <a href="https://www.instagram.com/oberdoerferkrebs/" rel="noopener">@oberdoerferkrebs</a>
    </dd>
  </div>
  <div class="row">
    <dt>General</dt>
    <dd><a href="mailto:oberdoerferkrebs@gmail.com">oberdoerferkrebs@gmail.com</a></dd>
  </div>
  <div class="row">
    <dt>Location</dt>
    <dd>Copenhagen, DK</dd>
  </div>
</dl>

<style>
  .contact-list {
    display: grid;
    gap: 0.5rem;
  }

  .row {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1.25rem;
    align-items: baseline;
  }

  dt {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  dd {
    font-size: 0.9rem;
  }

  dd a {
    text-decoration: none;
  }

  dd a:hover {
    color: var(--color-muted);
  }
</style>
